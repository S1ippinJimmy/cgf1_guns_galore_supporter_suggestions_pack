<Defs>
	<!-- Backpack -->
	
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>CGF1_MWP_Apparel_SchoolBag</defName>
		<label>Schoolbag</label>
		<description>A basic backpack designed for carrying around school supplies. Not particularly rugged as it is only designed for casual use.</description>
		<graphicData>
			<texPath>CGF1/Apparel/SchoolBag/SchoolBag</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<techLevel>Industrial</techLevel>
		<tradeability>Sellable</tradeability>
		<generateCommonality>0.001</generateCommonality>
		<generateAllowChance>0.15</generateAllowChance>
		<costList>
			<Cloth>50</Cloth>
		</costList>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToMake>2400</WorkToMake>
			<Mass>2</Mass>
			<Flammability>0.4</Flammability>
			<EquipDelay>2</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<VEF_MassCarryCapacity MayRequire="VanillaExpanded.VAEAccessories">50</VEF_MassCarryCapacity>
		</equippedStatOffsets>
		<thingCategories Inherit='False'>
			<li>ApparelUtility</li>
		</thingCategories>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
			</bodyPartGroups>
			<wornGraphicPath>CGF1/Apparel/SchoolBag/SchoolBag</wornGraphicPath>
			<careIfWornByCorpse>false</careIfWornByCorpse>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<careIfDamaged>false</careIfDamaged>
			<layers>
				<li>Belt</li>
			</layers>
			<tags>
				<li>IndustrialAdvanced</li>
			</tags>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicData>
				<renderUtilityAsPack>true</renderUtilityAsPack>
				<north>
					<offset>(0.0,-0.1)</offset>
					<hulk>
						<offset>(-0.0,-0.1)</offset>
					</hulk>
					<fat>
						<offset>(-0.0,-0.0)</offset>
					</fat>
					<thin>
						<offset>(0.0,-0.0)</offset>
					</thin>
				</north>
				<south>
					<offset>(0.0,0.20)</offset>
					<female>
						<offset>(0.0,-0.2)</offset>
					</female>
					<hulk>
						<offset>(-0.0,-0.0)</offset>
					</hulk>
					<fat>
						<offset>(-0.0,-0.0)</offset>
					</fat>
					<thin>
						<offset>(-0.0,-0.25)</offset>
					</thin>
				</south>
				<east>
					<offset>(-0.4,-0.1)</offset>
					<hulk>
						<offset>(-0.15,-0.0)</offset>
					</hulk>
					<fat>
						<offset>(-0.10,-0.0)</offset>
					</fat>
					<thin>
						<offset>(0.05,-0.0)</offset>
					</thin>
				</east>
				<west>
					<offset>(0.4,-0.1)</offset>
					<hulk>
						<offset>(0.15,-0.0)</offset>
					</hulk>
					<fat>
						<offset>(0.10,-0.0)</offset>
					</fat>
					<thin>
						<offset>(-0.05,-0.0)</offset>
					</thin>
				</west>
				<male>
					<scale>(0.67,0.67)</scale>
				</male>
				<female>
					<scale>(0.67,0.67)</scale>
				</female>
				<thin>
					<scale>(0.62,0.62)</scale>
				</thin>
				<hulk>
					<scale>(0.82,0.82)</scale>
				</hulk>
				<fat>
					<scale>(0.82,0.82)</scale>
				</fat>
			</wornGraphicData>
		</apparel>
		<recipeMaker>
			<researchPrerequisite>CGF1_MWP_Research_T4_IndustrialApparel</researchPrerequisite>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Tailor</effectWorking>
			<soundWorking>Recipe_Tailor</soundWorking>
			<skillRequirements>
				<Crafting>3</Crafting>
			</skillRequirements>
			<recipeUsers Inherit="False">
				<li>ElectricTailoringBench</li>
				<li>HandTailoringBench</li>
			</recipeUsers>
		</recipeMaker>
		<tradeTags>
			<li>CGF1_GunsGalore_SupporterSuggestions_Clothing</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options">
			<options>
				<li>
					<weight>5</weight> <!-- Dark Blue -->
					<only>(70,95,245)</only>
				</li>
				<li>
					<weight>10</weight> <!-- Red -->
					<only>(150,60,65)</only>
				</li>
				<li>
					<weight>2</weight> <!-- Gold -->
					<only>(245,170,25)</only>
				</li>
				<li>
					<weight>1</weight> <!-- Pink -->
					<only>(245,170,220)</only>
				</li>
			</options>
		</colorGenerator>
	</ThingDef>

