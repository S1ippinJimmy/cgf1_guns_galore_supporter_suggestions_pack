<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="CGF1_MWP_SMG_T0">
		<defName>CGF1_MWP_HK_UMP10_</defName>
		<label>HK UMP-10</label>
		<description>Caliber: 10mm Auto. 30-round detachable mag. Select-Fire.</description>
		<graphicData>
			<texPath>CGF1/Gun/HK_UMP10</texPath>
			<drawSize>0.96</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>60</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>25000</WorkToMake>
			<Mass>2.65</Mass>
			<AccuracyTouch>0.85</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.35</AccuracyMedium>
			<AccuracyLong>0.20</AccuracyLong>
			<RangedWeapon_Cooldown>1.6</RangedWeapon_Cooldown>
		</statBases>
		<equippedAngleOffset>40</equippedAngleOffset>
		<weaponTags>
			<li>CGF1_SMG_Military</li>
			<li>CGF1_SMG_Military_Advanced</li>
		</weaponTags>
		<weaponClasses>
			<li>ShortShots</li>
			<li>RangedLight</li>
		</weaponClasses>
		<tradeTags>
			<li>CGF1_GunsGalore_SupporterSuggestions</li>
			<li>CGF1_GunsGalore_SupporterSuggestions_Gun</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_10mmAuto_Auto</defaultProjectile>
				<warmupTime>0.9</warmupTime>
				<range>25.9</range>
				<burstShotCount>5</burstShotCount>
				<ticksBetweenBurstShots>8</ticksBetweenBurstShots>
				<soundCast>CGF1_GG_SFXR_Pistol3</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(0.75,0.75)</drawSize>
				<offsets>
					<li>(0.40,0.07)</li>
				</offsets>
			</li>
		</modExtensions>
		<generateCommonality>0.0125</generateCommonality> <!-- Rare -->
	</ThingDef>
	
