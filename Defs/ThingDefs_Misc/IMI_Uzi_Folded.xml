<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<ThingDef ParentName="CGF1_MWP_SMG_T1">
		<defName>CGF1_MWP_IMI_Uzi_Folded_</defName>
		<label>IMI Uzi (Folded)</label>
		<description>Caliber: 9x19mm Parabellum. 32-round detachable mag. Select-Fire.</description>
		<graphicData>
			<texPath>CGF1/Gun/IMI_Uzi_Folded</texPath>
			<drawSize>1.00</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T8_AtomicAgeFirearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>50</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>20000</WorkToMake>
			<Mass>3.5</Mass>
			<AccuracyTouch>0.85</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.35</AccuracyMedium>
			<AccuracyLong>0.20</AccuracyLong>
			<RangedWeapon_Cooldown>1.65</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>CGF1_SMG_Civilian</li>
			<li>CGF1_SMG_Military</li>
			<li>CGF1_SMG_Military_Advanced</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedLight</li>
			<li>ShortShots</li>
		</weaponClasses>
		<tradeTags Inherit="False">
			<li>CGF1_GunsGalore_NoSpawn</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_9x19mmParabellum_Pistol</defaultProjectile>
				<warmupTime>0.9</warmupTime>
				<range>25.9</range>
				<burstShotCount>5</burstShotCount>
				<ticksBetweenBurstShots>9</ticksBetweenBurstShots>
				<soundCast>CGF1_MWP_SFX_SMG4</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(0.6,0.6)</drawSize>
				<offsets>
					<li>(0.37,0.12)</li>
				</offsets>
			</li>
		</modExtensions>
		<generateCommonality>1.5</generateCommonality> <!-- Everywhere -->
		<thingSetMakerTags>
			<li>CGF1_GunsGalore_RewardAncient_Common</li>
		</thingSetMakerTags>
	</ThingDef>
	
