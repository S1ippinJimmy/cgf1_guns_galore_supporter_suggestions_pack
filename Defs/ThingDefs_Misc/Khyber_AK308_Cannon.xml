				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>70</Steel>
			<ComponentIndustrial>7</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>40000</WorkToMake>
			<Mass>3.8</Mass>
			<AccuracyTouch>0.55</AccuracyTouch>
