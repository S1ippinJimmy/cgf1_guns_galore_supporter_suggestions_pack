<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="CGF1_MWP_SemiBattleRifle_T1">
		<defName>CGF1_MWP_M1Garand_</defName>
		<label>M1 Garand</label>
		<description>Caliber: .30-06 Springfield. 8-round internal mag. Semi-Automatic.</description>
		<graphicData>
			<texPath>CGF1/Gun/M1_Garand</texPath>
			<drawSize>1.05</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T7_WW2Firearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>60</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>20000</WorkToMake>
			<Mass>4.3</Mass>
			<AccuracyTouch>0.55</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.75</AccuracyMedium>
			<AccuracyLong>0.60</AccuracyLong>
			<RangedWeapon_Cooldown>1.1</RangedWeapon_Cooldown>
		</statBases>
		<equippedAngleOffset>40</equippedAngleOffset>
		<weaponTags>
			<li>CGF1_Rifle_Civilian</li>
			<li>CGF1_Rifle_Military</li>
			<li>CGF1_Rifle_Military_Advanced</li>
		</weaponTags>
		<tradeTags>
			<li>CGF1_GunsGalore_SupporterSuggestions</li>
			<li>CGF1_GunsGalore_SupporterSuggestions_Gun</li>
			<li>CGF1_GunsGalore_WWIIUSA</li>
			<li>CGF1_GunsGalore_WWIIUSA_Rifle</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_3006Springfield_Rifle</defaultProjectile>
				<warmupTime>1.3</warmupTime>
				<range>33.9</range>
				<soundCast>CGF1_MWP_SFX_Rifle_Semi2</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(0.9,0.9)</drawSize>
				<offsets>
					<li>(0.60,0.09)</li>
				</offsets>
			</li>
		</modExtensions>
		<generateCommonality>0.05</generateCommonality> <!-- Uncommon -->
		<thingSetMakerTags>
			<li>CGF1_GunsGalore_RewardAncient_Common</li>
		</thingSetMakerTags>
	</ThingDef>
	
