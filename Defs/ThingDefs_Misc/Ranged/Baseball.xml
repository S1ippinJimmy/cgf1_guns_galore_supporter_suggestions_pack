<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="CGF1_MWP_BaseHumanMakeableRanged_Throwing">
		<defName>CGF1_MWP_Baseball_</defName>
		<label>baseball</label>
		<description>A ball used in the sport of baseball. Baseballs consist of a rubber or cork center that is wrapped in yarn and covered with cowhide or synthetic leather. The leather is typically sewn on in two pieces that are shaped like a saddle. Though intended for sport, baseballs are solid objects thrown at high speeds, and this can cause significant injury on impact. A hit-by-pitch (HBP) is an unfortunately common occurrence in baseball games, caused by both badly placed pitches and intentional "plunking." Some baseball impacts have caused permanent wounds, and one player- Ray Chapman- died after being hit by a pitch in 1920.</description>
		<graphicData>
			<texPath>CGF1/Ranged/Baseball</texPath>
			<drawSize>0.99</drawSize>
		</graphicData>
		<soundInteract>ThrowGrenade</soundInteract>
		<recipeMaker>
			<recipeUsers>
				<li>CraftingSpot</li>
				<li>HandTailoringBench</li>
				<li>ElectricTailoringBench</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T4_ToyWeapons</researchPrerequisite>
			<skillRequirements/>
		</recipeMaker>
		<costList>
			<Cloth>30</Cloth>
		</costList>
		<statBases>
			<WorkToMake>1000</WorkToMake>
			<Mass>0.2</Mass>
			<AccuracyTouch>0.7</AccuracyTouch>
			<AccuracyShort>0.5</AccuracyShort>
			<AccuracyMedium>0.4</AccuracyMedium>
			<AccuracyLong>0.2</AccuracyLong>
			<RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
		</statBases>
		<relicChance>0.0</relicChance>
		<techLevel>Industrial</techLevel>
		<weaponTags>		
			<li>CGF1_Weapon_Pirate_Drifter</li>
			<li>CGF1_Weapon_Pigskin_Villager</li>
			<li>CGF1_Weapon_Outlander_Villager</li>
			<li>CGF1_Weapon_Ideology_Outlander</li>
			<li>CGF1_Weapon_Royalty_Refugee</li>
			<li>CGF1_Weapon_Ideology_Beggar</li>
		</weaponTags>
		<weaponClasses>
