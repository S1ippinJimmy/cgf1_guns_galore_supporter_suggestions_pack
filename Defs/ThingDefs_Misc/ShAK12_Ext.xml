			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>70</Steel>
			<ComponentIndustrial>7</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>42500</WorkToMake>
			<Mass>6.5</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
			<AccuracyShort>0.70</AccuracyShort>
			<AccuracyMedium>0.65</AccuracyMedium>
			<AccuracyLong>0.55</AccuracyLong>
			<RangedWeapon_Cooldown>1.7</RangedWeapon_Cooldown>
		</statBases>
		<equippedAngleOffset>40</equippedAngleOffset>
		<weaponTags>
			<li>CGF1_AR_Military</li>
			<li>CGF1_AR_Military_Advanced</li>
			
			<li>CGF1_Weapon_HLRW_CombineSoldier</li>
		</weaponTags>
		<tradeTags>
			<li>CGF1_GunsGalore_SupporterSuggestions</li>
			<li>CGF1_GunsGalore_SupporterSuggestions_Gun</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_127x55mmSTs130_Auto</defaultProjectile>
				<warmupTime>1</warmupTime>
				<range>30.9</range>
				<burstShotCount>4</burstShotCount>
				<ticksBetweenBurstShots>8</ticksBetweenBurstShots>
				<soundCast>CGF1_MWP_SFX_Rifle_Semi7</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(0.9,0.9)</drawSize>
				<offsets>
					<li>(0.42,0.06)</li>
				</offsets>
			</li>
		</modExtensions>
		<generateCommonality>0.20</generateCommonality> <!-- Common -->
	</ThingDef>
	
