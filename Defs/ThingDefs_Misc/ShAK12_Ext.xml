<Defs>

	<ThingDef ParentName="CGF1_MWP_AssaultRifle_T0">
		<defName>CGF1_MWP_ShAK12_Ext_</defName>
		<label>ShAK-12 (Ext)</label>
		<description>Caliber: 12.7x55mm STs-130. 20-round detachable mag. Select-Fire.</description>
		<graphicData>
			<texPath>CGF1/Gun/ShAK12_Ext</texPath>
			<drawSize>1.00</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
